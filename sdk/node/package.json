{
  "name": "kronvex",
  "version": "0.3.0",
  "description": "Persistent memory for AI agents \u2014 Kronvex Node.js SDK",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "memory",
    "agents",
    "llm",
    "kronvex",
    "rag"
  ],
  "author": "Kronvex <hello@kronvex.io>",
  "license": "MIT",
  "homepage": "https://kronvex.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/Daftgoldens/Kronvex"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}