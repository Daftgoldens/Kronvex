# Database (PostgreSQL + pgvector)
# Local: use docker-compose defaults below
# Production: postgresql+asyncpg://user:pass@host:5432/dbname
DATABASE_URL=postgresql+asyncpg://memory:memory@localhost:5432/agentmemory

# OpenAI (used for text-embedding-3-small)
OPENAI_API_KEY=sk-...

# Stripe (payments)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Supabase (auth, optional — for JWT verification)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# Email (Resend)
RESEND_API_KEY=re_...

# App
FRONTEND_URL=https://kronvex.io
ALLOWED_ORIGINS=https://kronvex.io,https://dashboard.kronvex.io

# Admin (optional)
ADMIN_TOKEN=

# Sentry (optional — leave empty to disable)
SENTRY_DSN=
